<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B2A">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1B263B"
        android:padding="15dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="←"
            android:textSize="24sp"
            android:backgroundTint="#415A77"
            android:textColor="#E0E1DD"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👤 Profile"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E0E1DD"
            android:gravity="center"
            android:layout_gravity="center_vertical"/>

        <View
            android:layout_width="50dp"
            android:layout_height="50dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Profile Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1B263B"
                android:padding="25dp"
                android:elevation="4dp"
                android:layout_marginBottom="25dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="60sp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="15dp"/>

                <TextView
                    android:id="@+id/usernameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#E0E1DD"
                    android:layout_gravity="center"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MovieSphere Member"
                    android:textSize="16sp"
                    android:textColor="#778DA9"
                    android:layout_gravity="center"/>

            </LinearLayout>

            <!-- Menu Options -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 My Collection"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#E0E1DD"
                android:layout_marginBottom="15dp"/>

            <!-- History Button -->
            <LinearLayout
                android:id="@+id/historyLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1B263B"
                android:padding="20dp"
                android:layout_marginBottom="15dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📺 History"
                    android:textSize="18sp"
                    android:textColor="#E0E1DD"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="24sp"
                    android:textColor="#778DA9"/>

            </LinearLayout>

            <!-- My Favourites Button -->
            <LinearLayout
                android:id="@+id/favouritesLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#1B263B"
                android:padding="20dp"
                android:layout_marginBottom="30dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="❤️ My Favourites"
                    android:textSize="18sp"
                    android:textColor="#E0E1DD"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="→"
                    android:textSize="24sp"
                    android:textColor="#778DA9"/>

            </LinearLayout>

            <!-- Logout Button -->
            <Button
                android:id="@+id/logoutButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="🚪 Logout"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#E0E1DD"
                android:textColor="#0D1B2A"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>