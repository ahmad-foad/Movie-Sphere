<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B2A"
    android:padding="30dp"
    android:gravity="center">

    <!-- Logo/Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎬 MovieSphere"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#E0E1DD"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Discover Your Next Favorite Movie"
        android:textSize="14sp"
        android:textColor="#778DA9"
        android:layout_marginBottom="50dp"/>

    <!-- Login Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1B263B"
        android:padding="25dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#E0E1DD"
            android:layout_marginBottom="25dp"/>

        <!-- Username -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textSize="14sp"
            android:textColor="#778DA9"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/usernameEditText"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your username"
            android:textColorHint="#415A77"
            android:textColor="#E0E1DD"
            android:background="#0D1B2A"
            android:padding="12dp"
            android:layout_marginBottom="20dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="14sp"
            android:textColor="#778DA9"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/passwordEditText"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Enter your password"
            android:textColorHint="#415A77"
            android:textColor="#E0E1DD"
            android:background="#0D1B2A"
            android:padding="12dp"
            android:inputType="textPassword"
            android:layout_marginBottom="30dp"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/loginButton"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/login"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0D1B2A"
            android:backgroundTint="#E0E1DD"
            android:layout_marginBottom="15dp"/>

        <!-- Sign Up Link -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don't have an account? "
                android:textSize="14sp"
                android:textColor="#778DA9"/>

            <TextView
                android:id="@+id/signUpTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sign_up"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#E0E1DD"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>