<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B2A">

    <!-- Back Button Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1B263B"
        android:padding="15dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/backButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="⬅️"
            android:textSize="20sp"
            android:background="?attr/selectableItemBackground"
            android:textColor="#E0E1DD"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Movie Details"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#E0E1DD"
            android:gravity="center"
            android:paddingHorizontal="16dp"/>

        <View
            android:layout_width="50dp"
            android:layout_height="50dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Movie Poster with Gradient Overlay -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="350dp">

                <ImageView
                    android:id="@+id/moviePosterImageView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#415A77"/>

                <!-- Gradient Overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_overlay"/>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Movie Title -->
                <TextView
                    android:id="@+id/movieTitleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Movie Title"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#E0E1DD"
                    android:layout_marginBottom="10dp"/>

                <!-- Year, Rating, Runtime in Info Cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="15dp"
                    android:gravity="center">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#1B263B"
                            android:padding="12dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📅"
                                android:textSize="20sp"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/movieYearTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2020"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#E0E1DD"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#1B263B"
                            android:padding="12dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐"
                                android:textSize="20sp"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/movieRatingTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="8.0"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#FFD700"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#1B263B"
                            android:padding="12dp"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⏱️"
                                android:textSize="20sp"
                                android:layout_marginBottom="4dp"/>

                            <TextView
                                android:id="@+id/movieRuntimeTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="120m"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#E0E1DD"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- Genre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎭 Genre"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFD700"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/movieGenreTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Action, Drama"
                    android:textSize="14sp"
                    android:textColor="#778DA9"
                    android:layout_marginBottom="20dp"/>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="25dp"
                    android:gravity="center">

                    <Button
                        android:id="@+id/favouriteButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="🤍 Favourite"
                        android:textSize="14sp"
                        android:backgroundTint="#1B263B"
                        android:textColor="#E0E1DD"
                        android:layout_marginRight="8dp"/>

                    <Button
                        android:id="@+id/shareButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="📤 Share"
                        android:textSize="14sp"
                        android:backgroundTint="#1B263B"
                        android:textColor="#E0E1DD"
                        android:layout_marginRight="8dp"/>

                    <Button
                        android:id="@+id/trailerButton"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="🎬 Trailer"
                        android:textSize="14sp"
                        android:backgroundTint="#FFD700"
                        android:textColor="#0D1B2A"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Plot Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📖 Synopsis"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFD700"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/moviePlotTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Movie plot..."
                    android:textSize="14sp"
                    android:textColor="#B0BAC9"
                    android:layout_marginBottom="25dp"
                    android:lineSpacingMultiplier="1.2"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
