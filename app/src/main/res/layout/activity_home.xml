<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B2A">

    <!-- Header with Gradient Background -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_header"
        android:padding="15dp"
        android:elevation="8dp">

        <!-- Title Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🎬 MovieSphere"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#E0E1DD"/>

        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore thousands of movies"
            android:textSize="12sp"
            android:textColor="#B0BAC9"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">

            <!-- Search Bar with Icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/rounded_search_background"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔍"
                    android:textSize="18sp"
                    android:layout_marginRight="8dp"/>

                <EditText
                    android:id="@+id/searchEditText"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search movies..."
                    android:padding="12dp"
                    android:textColor="#E0E1DD"
                    android:textColorHint="#415A77"
                    android:textSize="16sp"
                    android:inputType="text"/>

                <Button
                    android:id="@+id/top250Button"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Trending/Popular Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Trending Now"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFD700"
                android:layout_marginBottom="12dp"/>

            <!-- Genre Filters with Chips -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎭 Filter by Genre"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E0E1DD"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="8dp"/>

            <!-- Genre Checkboxes Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/actionCheckBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎬 Action"
                    android:textColor="#E0E1DD"
                    android:textSize="13sp"
                    android:buttonTint="#FFD700"/>

                <CheckBox
                    android:id="@+id/comedyCheckBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="😂 Comedy"
                    android:textColor="#E0E1DD"
                    android:textSize="13sp"
                    android:buttonTint="#FFD700"/>

            </LinearLayout>

            <!-- Genre Checkboxes Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <CheckBox
                    android:id="@+id/dramaCheckBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🎭 Drama"
                    android:textColor="#E0E1DD"
                    android:textSize="13sp"
                    android:buttonTint="#FFD700"/>

                <CheckBox
                    android:id="@+id/horrorCheckBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="😱 Horror"
                    android:textColor="#E0E1DD"
                    android:textSize="13sp"
                    android:buttonTint="#FFD700"/>

            </LinearLayout>

            <!-- Genre Checkboxes Row 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <CheckBox
                    android:id="@+id/scifiCheckBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🚀 Sci-Fi"
                    android:textColor="#E0E1DD"
                    android:textSize="13sp"
                    android:buttonTint="#FFD700"/>

                <CheckBox
                    android:id="@+id/thrillerCheckBox"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚡ Thriller"
                    android:textColor="#E0E1DD"
                    android:textSize="13sp"
                    android:buttonTint="#FFD700"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#415A77"
                android:layout_marginBottom="15dp"/>

            <!-- Movies List Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎬 Movies"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#E0E1DD"
                android:layout_marginBottom="15dp"/>

            <!-- Movies ListView -->
            <ListView
                android:id="@+id/moviesListView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1B263B"
        android:elevation="8dp"
        android:gravity="center"
        android:paddingVertical="8dp">

        <Button
            android:id="@+id/navHomeButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="🏠\nHome"
            android:textSize="12sp"
            android:textColor="#FFD700"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:padding="8dp"/>

        <Button
            android:id="@+id/navFavouritesButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="❤️\nFavourites"
            android:textSize="12sp"
            android:textColor="#778DA9"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:padding="8dp"/>

        <Button
            android:id="@+id/navHistoryButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="📺\nHistory"
            android:textSize="12sp"
            android:textColor="#778DA9"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:padding="8dp"/>

        <Button
            android:id="@+id/navProfileButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="👤\nProfile"
            android:textSize="12sp"
            android:textColor="#778DA9"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:padding="8dp"/>

    </LinearLayout>

</LinearLayout>
